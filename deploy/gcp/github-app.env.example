# Copy this file to deploy/gcp/github-app.env on the VM and fill in the values
# after creating and installing the GitHub App for comment sync.
#
# These variables are reserved for the upcoming outbound comment-sync worker.

GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=

# Set one of the private key options below.
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_APP_PRIVATE_KEY_PEM=

# Leave blank to use api.github.com.
GITHUB_BASE_URL=
