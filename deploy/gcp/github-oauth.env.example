# Copy this file to deploy/gcp/github-oauth.env on the VM and fill in the values
# if you want to override the default GitHub OAuth device-flow settings.

PRTAGS_GITHUB_OAUTH_CLIENT_ID=
# Leave blank to use the default scope: read:org repo
PRTAGS_GITHUB_OAUTH_SCOPE=
# Leave blank to use github.com.
PRTAGS_GITHUB_OAUTH_BASE_URL=
# Leave blank to use api.github.com.
PRTAGS_GITHUB_API_URL=
